MONGO_INITDB_ROOT_USERNAME=root
MONGO_INITDB_ROOT_PASSWORD=mongo-secret
MONGO_INITDB_DATABASE=track-hive
ME_CONFIG_MONGODB_URL=mongodb://root:mongo-secret@mongo-database:27017/  # protocol://username:password@host:port/database
ME_CONFIG_BASICAUTH_ENABLED=true
ME_CONFIG_BASICAUTH_USERNAME=root
ME_CONFIG_BASICAUTH_PASSWORD=mongo-express-secret